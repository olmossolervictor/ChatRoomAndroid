<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <ImageView
        android:id="@+id/dialogImgFoto"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_dialog_avatar"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera" />

    <TextView
        android:id="@+id/dialogTextNombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:fontFamily="@font/poppins_bold"
        android:gravity="center"
        android:textColor="@color/text_high"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/dialogTextApellidos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:textColor="@color/text_medium"
        android:textSize="14sp" />

    <Button
        android:id="@+id/dialogBtnChatPrivado"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_dialog_primary_button"
        android:fontFamily="@font/poppins_bold"
        android:text="Chat Privado"
        android:textAllCaps="false"
        android:textColor="@color/white" />

    <Button
        android:id="@+id/dialogBtnDenunciar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_dialog_destructive_button"
        android:fontFamily="@font/poppins_bold"
        android:text="Denunciar"
        android:textAllCaps="false"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/dialogBtnExpulsar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="#B71C1C"
        android:fontFamily="@font/poppins_bold"
        android:text="Expulsar de la Sala (Admin)"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:visibility="gone" />

</LinearLayout>