<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/capaFrenteSala"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_subtle"
    app:cardBackgroundColor="@color/surface_card"

    android:descendantFocusability="blocksDescendants"
    android:clickable="false"
    android:focusable="false"
    android:duplicateParentState="true"

    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:src="@drawable/foto_sala" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/textContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/btnEnterContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/textNombreSala"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE DE LA SALA"
                android:textColor="@color/text_high"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/textTiempoSala"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCESO CONCEDIDO"
                android:textColor="@color/secondary_dark"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:alpha="0.8" />
        </LinearLayout>

        <ImageView
            android:layout_width="38dp"
            android:layout_height="31dp"
            android:layout_marginStart="80dp"
            android:src="@drawable/icon_sala"
            app:layout_constraintBottom_toBottomOf="@id/btnEnterContainer"
            app:layout_constraintEnd_toEndOf="@+id/btnEnterContainer"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@+id/textContainer"
            app:layout_constraintTop_toTopOf="@id/btnEnterContainer"
            app:layout_constraintVertical_bias="0.666"
            app:tint="@color/text_medium"
            tools:ignore="UnknownId" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
