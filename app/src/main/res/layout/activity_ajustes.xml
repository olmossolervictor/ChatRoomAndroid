<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_main"
        app:elevation="0dp"> <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarAjustes"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/text_high">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AJUSTES"
            android:textColor="@color/text_high"
            android:textSize="17sp"
            android:fontFamily="@font/poppins_bold" /> </androidx.appcompat.widget.Toolbar>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="APARIENCIA"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/poppins_bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:letterSpacing="0.04"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tema de la aplicación"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/radioTema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioTemaSistema"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sistema"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/radioTemaClaro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Claro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"/>

                    <RadioButton
                        android:id="@+id/radioTemaOscuro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Oscuro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"/>
                </RadioGroup>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_subtle"
                android:layout_marginStart="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tamaño de letra del chat"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/radioTamanoFuente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioFuentePequena"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pequeña"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"/>

                    <RadioButton
                        android:id="@+id/radioFuenteNormal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Normal"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/radioFuenteGrande"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Grande"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_high"/>
                </RadioGroup>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_subtle"
                android:layout_marginStart="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UBICACIÓN"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/poppins_bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="18dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_settings_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Localización"
                    android:textColor="@color/text_high"
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchGps"
                    style="@style/Widget.App.Switch"
                    android:layout_width="60dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="16dp"
                    android:thumb="@drawable/switch_thumb_premium"
                    android:track="@drawable/switch_track_premium"
                    android:splitTrack="false"
                    android:showText="false"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_subtle"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:layout_marginTop="14dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CÁMARA"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/poppins_bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:letterSpacing="0.04"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:paddingStart="18dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_settings_row">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Permiso de Cámara"
                    android:textColor="@color/text_high"
                    android:fontFamily="@font/poppins_medium"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchCamara"
                    style="@style/Widget.App.Switch"
                    android:layout_width="60dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="16dp"
                    android:thumb="@drawable/switch_thumb_premium"
                    android:track="@drawable/switch_track_premium"
                    android:splitTrack="false"
                    android:showText="false"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_subtle"
                android:layout_marginStart="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
