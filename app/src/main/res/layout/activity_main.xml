<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayoutMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 🏛️ REFINED HEADER -->
            <com.google.android.material.appbar.AppBarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_main"
                app:elevation="0dp">

                <androidx.appcompat.widget.Toolbar
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="?attr/actionBarSize"
                    app:contentInsetStartWithNavigation="0dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageButton
                            android:id="@+id/btnMenuDrawerMain"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_centerVertical="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            android:padding="12dp"
                            app:tint="@color/text_high" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/btnMenuDrawerMain"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/textSalaTitulo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sala de Chat"
                                android:textColor="@color/text_high"
                                android:textSize="18sp"
                                android:fontFamily="@font/poppins_bold"
                                android:letterSpacing="-0.02" />

                            <TextView
                                android:id="@+id/textSalaUsuarios"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sesión activa"
                                android:textColor="@color/success_main"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/timerPill"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="16dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="@color/error_main"
                            tools:visibility="visible"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/textTiempoRestante"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="00:00"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_bold" />
                        </com.google.android.material.card.MaterialCardView>
                    </RelativeLayout>
                </androidx.appcompat.widget.Toolbar>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle" />
            </com.google.android.material.appbar.AppBarLayout>

            <!-- 💬 CHAT AREA -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ListView
                    android:id="@+id/listMessages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="8dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="84dp"
                    android:divider="@null"
                    android:dividerHeight="0dp"
                    android:stackFromBottom="true"
                    android:transcriptMode="alwaysScroll"
                    android:clipToPadding="false"
                    android:scrollbarStyle="outsideOverlay"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_mensaje"/>

                <!-- ⌨️ INPUT PANEL -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutInputMessageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_margin="12dp"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/surface_card"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <LinearLayout
                        android:id="@+id/layoutInputMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="6dp">

                        <EditText
                            android:id="@+id/editMessage"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Escribe un mensaje..."
                            android:background="@android:color/transparent"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="12dp"
                            android:inputType="textShortMessage|textCapSentences"
                            android:textColor="@color/text_high"
                            android:textColorHint="@color/text_low"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_medium"
                            android:maxLines="5"
                            android:importantForAutofill="no"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSend"
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_margin="2dp"
                            app:icon="@android:drawable/ic_menu_send"
                            app:iconTint="@color/white"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="24dp"
                            android:elevation="0dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- 🚪 DRAWER REFINADO -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/surface_card"
        android:clickable="true"
        android:focusable="true"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="64dp"
            android:paddingBottom="32dp"
            android:background="@color/accent_soft">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/white">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgDrawerFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_camera"
                    android:padding="2dp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textDrawerNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Usuario"
                android:textColor="@color/text_high"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SALA ACTUAL"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/drawerVolverInicio"
                    style="@style/DrawerItemStylePremium"
                    android:text="Volver al inicio"
                    android:drawableStart="@android:drawable/ic_menu_revert" />

                <View style="@style/DrawerDivider" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/drawerSalirSala"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Abandonar sala"
                    android:textColor="@color/error_main"
                    android:gravity="start|center_vertical"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconTint="@color/error_main"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/error_bg"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
