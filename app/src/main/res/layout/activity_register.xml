<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ELEMENTO DECORATIVO SUPERIOR -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-160dp"
        android:layout_marginEnd="-160dp"
        android:background="@drawable/bg_icon_chat"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="60dp"
            android:paddingBottom="48dp"
            android:gravity="center_horizontal">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/reg_title"
                android:textColor="@color/text_high"
                android:textSize="32sp"
                android:letterSpacing="-0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp"
                android:text="@string/reg_subtitle"
                android:textColor="@color/text_medium"
                android:textSize="15sp"
                android:letterSpacing="0.02" />

            <!-- SELECTOR DE FOTO MODERNO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_icon_chat"
                        android:alpha="0.1" />

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgUser"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_camera"
                        app:civ_border_color="@color/primary"
                        app:civ_border_width="2.5dp"
                        app:civ_circle_background_color="@color/surface_card" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnSelectPhoto"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="4dp"
                        app:cardBackgroundColor="@color/primary"
                        app:cardCornerRadius="19dp"
                        app:cardElevation="6dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/white">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="@color/white" />
                    </com.google.android.material.card.MaterialCardView>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Añadir foto de perfil"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>

            <!-- FORMULARIO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="@string/reg_nombre_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRegNombre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="18dp"
                            android:inputType="textPersonName"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.App.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/reg_apellidos_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRegApellidos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingVertical="18dp"
                            android:inputType="textPersonName"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_fecha_nac_hint"
                    app:startIconDrawable="@android:drawable/ic_menu_my_calendar">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegNombreUsuario"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_username_hint"
                    app:startIconDrawable="@android:drawable/ic_menu_edit">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegNombreUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="text"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textNombreUsuarioError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reg_error_username_exists"
                    android:textColor="@color/error_main"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginTop="-12dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="20dp"
                    android:fontFamily="@font/poppins_bold" />

                <LinearLayout
                    android:id="@+id/layoutSugerencias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reg_suggested_usernames"
                        android:textSize="12sp"
                        android:layout_marginStart="20dp"
                        android:textColor="@color/text_medium" />
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/layoutBotonesSugerencias"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp" />
                    </HorizontalScrollView>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutRegEmail"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_email_hint"
                    app:startIconDrawable="@android:drawable/ic_dialog_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textEmailError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reg_error_email_exists"
                    android:textColor="@color/error_main"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginTop="-12dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="20dp"
                    android:fontFamily="@font/poppins_bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_telefono_hint"
                    app:startIconDrawable="@android:drawable/ic_menu_call">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="phone"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="@string/reg_password_hint"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="textPassword"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/layoutTerminos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <CheckBox
                        android:id="@+id/checkTerminos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/secondary" />

                    <TextView
                        android:id="@+id/textVerTerminos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reg_terms_accept"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_button"
                    android:text="@string/reg_btn_register"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:fontFamily="@font/poppins_bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="24dp"
                    app:elevation="8dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/textBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:padding="12dp"
                android:text="@string/reg_back_to_login"
                android:textColor="@color/text_high"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>