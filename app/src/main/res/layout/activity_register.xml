<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_main"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarRegister"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/text_high"
            android:visibility="gone" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:paddingBottom="48dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/reg_title"
                android:textColor="@color/text_high"
                android:textSize="30sp"
                android:letterSpacing="0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"
                android:text="@string/reg_subtitle"
                android:textColor="@color/text_medium"
                android:textSize="15sp"
                android:alpha="0.8" />

            <RelativeLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_centerInParent="true"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgUser"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="8dp"
                        android:src="@drawable/defecto"
                        app:civ_circle_background_color="@color/bg_secondary" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnSelectPhoto"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/button_primary"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/white">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/white" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRegNombre"
                        style="@style/Widget.App.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="@string/reg_nombre_hint"
                        app:errorIconDrawable="@null"
                        app:errorIconTint="@android:color/transparent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRegNombre"
                            style="@style/Widget.App.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_medium" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRegApellidos"
                        style="@style/Widget.App.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/reg_apellidos_hint"
                        app:errorIconDrawable="@null"
                        app:errorIconTint="@android:color/transparent">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRegApellidos"
                            style="@style/Widget.App.TextInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:textSize="15sp"
                            android:fontFamily="@font/poppins_medium" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegEdad"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_fecha_nac_hint"
                    app:startIconDrawable="@drawable/icon_calendar_pequeno"
                    app:startIconTint="@color/text_low"
                    app:errorIconDrawable="@null"
                    app:errorIconTint="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegEdad"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="none"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegNombreUsuario"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:hint="@string/reg_username_hint"
                    app:startIconDrawable="@drawable/icon_user_pequeno"
                    app:startIconTint="@color/text_low"
                    app:errorIconDrawable="@null"
                    app:errorIconTint="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegNombreUsuario"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textNombreUsuarioError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reg_error_username_exists"
                    android:background="@drawable/bg_error_message"
                    android:textColor="@color/error_main"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:fontFamily="@font/poppins_medium" />

                <LinearLayout
                    android:id="@+id/layoutSugerencias"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reg_suggested_usernames"
                        android:textSize="12sp"
                        android:layout_marginStart="16dp"
                        android:textColor="@color/text_medium"
                        android:fontFamily="@font/poppins_medium" />
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:overScrollMode="never">
                        <LinearLayout
                            android:id="@+id/layoutBotonesSugerencias"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp"
                            android:paddingHorizontal="12dp" />
                    </HorizontalScrollView>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegTelefono"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/reg_telefono_hint"
                    app:startIconDrawable="@drawable/icon_phone_pequeno"
                    app:startIconTint="@color/text_low"
                    app:errorIconDrawable="@null"
                    app:errorIconTint="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegTelefono"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegEmail"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:hint="@string/reg_email_hint"
                    app:startIconDrawable="@drawable/icon_email_pequeno"
                    app:startIconTint="@color/text_low"
                    app:errorIconDrawable="@null"
                    app:errorIconTint="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegEmail"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/textEmailError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reg_error_email_exists"
                    android:background="@drawable/bg_error_message"
                    android:textColor="@color/error_main"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:fontFamily="@font/poppins_medium" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRegPassword"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="@string/reg_password_hint"
                    app:endIconMode="password_toggle"
                    app:endIconDrawable="@drawable/selector_password_toggle"
                    app:endIconTint="@color/text_low"
                    app:startIconDrawable="@drawable/icon_password_pequeno"
                    app:startIconTint="@color/text_low"
                    app:errorIconDrawable="@null"
                    app:errorIconTint="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editRegPassword"
                        style="@style/Widget.App.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@null"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/layoutTerminos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="4dp">

                    <CheckBox
                        android:id="@+id/checkTerminos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/primary" />

                    <TextView
                        android:id="@+id/textVerTerminos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reg_terms_accept"
                        android:textColor="@color/text_medium"
                        android:textSize="14sp"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/poppins_medium" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvGeneralError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/bg_error_message"
                    android:textColor="@color/error_main"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:lineSpacingExtra="2dp"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="Mensaje de error general aquí" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:text="@string/reg_btn_register"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    app:cornerRadius="16dp"
                    android:elevation="0dp"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRegLoginLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reg_have_account"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/textBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_login_here"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>