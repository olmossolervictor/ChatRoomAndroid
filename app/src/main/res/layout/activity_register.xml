<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro de Usuario"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/imgUser"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_camera"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="8dp"
            android:scaleType="centerCrop"/>

        <Button
            android:id="@+id/btnSelectPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Seleccionar Foto"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="6dp">

            <EditText
                android:id="@+id/editRegNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:hint="Nombre"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF"
                android:backgroundTint="#FFFFFF"
                android:inputType="textPersonName"
                android:textSize="14sp"/>

            <EditText
                android:id="@+id/editRegApellidos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:hint="Apellidos"
                android:textColor="#FFFFFF"
                android:textColorHint="#B3FFFFFF"
                android:backgroundTint="#FFFFFF"
                android:inputType="textPersonName"
                android:textSize="14sp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/editRegEdad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha de Nacimiento"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:inputType="number"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editRegTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Teléfono"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:inputType="phone"
            android:textSize="14sp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editRegEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo electrónico"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:inputType="textEmailAddress"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/textEmailError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ya existe una cuenta con este correo electrónico"
            android:textColor="#FF6B6B"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/editRegPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contraseña"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layoutTerminos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/checkTerminos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                app:buttonTint="#FFFFFF" />

            <TextView
                android:id="@+id/textVerTerminos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Acepto los términos y condiciones legales"
                android:textColor="#4DD0E1"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrarse"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta? Inicia sesión"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</ScrollView>