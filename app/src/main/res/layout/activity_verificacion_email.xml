<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/verificacion_titulo"
            android:textColor="@color/text_high"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textVerificacionEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:textColor="@color/text_medium"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/digit1"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:importantForAutofill="no"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/digit2"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/digit3"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/digit4"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/digit5"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/digit6"
                style="@style/DigitFieldStyle"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="@color/text_high"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerificarCodigo"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:text="@string/verificar_codigo"
            android:textColor="@color/white"
            app:backgroundTint="@color/button_primary_tint"
            app:cornerRadius="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_subtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="o"
                android:textColor="@color/text_medium" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/border_subtle" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerificarGoogle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:text="@string/verificar_google"
            android:textColor="@color/text_high"
            app:backgroundTint="@color/surface_card"
            app:cornerRadius="16dp"
            app:strokeColor="@color/border_subtle"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/textReenviarCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:text="@string/reenviar_codigo"
            android:textColor="@color/primary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
