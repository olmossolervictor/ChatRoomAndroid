<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_private"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 🏛️ PREMIUM TOOLBAR -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarPrivateChat"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIconTint="@color/text_high">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgToolbarFoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/defecto"
                        app:civ_border_width="1dp"
                        app:civ_border_color="@color/border_subtle" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textToolbarPrivateTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_high"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            tools:text="Nombre Usuario" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chat Privado Seguro"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.appcompat.widget.Toolbar>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_subtle" />
        </com.google.android.material.appbar.AppBarLayout>

        <!-- 💬 CHAT LIST -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/listMessagesPrivate"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:stackFromBottom="true"
                android:transcriptMode="alwaysScroll"
                android:clipToPadding="false"
                android:scrollbarStyle="outsideOverlay"
                android:overScrollMode="never" />

        </RelativeLayout>

        <!-- ⌨️ BOTTOM PANEL (Input + Request) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Private Request Card (Premium Style) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutSolicitudPrivada"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/bg_secondary"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_subtle"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textEstadoConversacionPrivada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Solicitud de chat pendiente"
                        android:textColor="@color/text_high"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:fontFamily="@font/poppins_medium" />

                    <LinearLayout
                        android:id="@+id/layoutBotonesSolicitudPrivada"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRejectPrivateRequest"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="RECHAZAR"
                            android:textColor="@color/error_main" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAcceptPrivateRequest"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="ACEPTAR"
                            android:backgroundTint="@color/primary"
                            android:textColor="@color/white"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Clean Input Capsule -->
            <LinearLayout
                android:id="@+id/inputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_secondary"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_subtle">

                    <EditText
                        android:id="@+id/editMessagePrivate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Escribe un mensaje privado..."
                        android:background="@android:color/transparent"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:inputType="textShortMessage|textCapSentences"
                        android:textColor="@color/text_high"
                        android:textColorHint="@color/text_low"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_regular"
                        android:maxLines="4"/>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendPrivate"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconTint="@color/white"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="24dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>