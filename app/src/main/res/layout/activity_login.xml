<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login">

    <ScrollView
        android:id="@+id/scrollLogin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="52dp"
            android:paddingEnd="24dp"
            android:paddingBottom="28dp">

            <!-- ICONO SUPERIOR -->
            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_icon_chat"
                android:elevation="4dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_dialog_email"
                    android:tint="@android:color/white" />
            </FrameLayout>

            <!-- TÍTULO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvChatroom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:letterSpacing="0.04"
                    android:text="CHATROOM "
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:letterSpacing="0.04"
                    android:text="QR"
                    android:textColor="@color/accent_neon"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="@string/login_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <!-- CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:elevation="8dp"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="24dp"
                android:paddingEnd="22dp"
                android:paddingBottom="22dp">

                <!-- EMAIL -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/login_email_hint"
                    app:boxBackgroundColor="@color/input_bg"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="@color/input_border"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="@color/text_hint"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="@color/accent_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textCursorDrawable="@drawable/cursor_blanco"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PASSWORD -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/login_password_hint"
                    app:boxBackgroundColor="@color/input_bg"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxStrokeColor="@color/input_border"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/accent_primary"
                    app:hintTextColor="@color/text_hint"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                    app:startIconTint="@color/accent_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textCursorDrawable="@drawable/cursor_blanco"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- REENVIAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/textResendVerification"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="@string/login_resend_prompt"
                    android:textAllCaps="false"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:backgroundTint="@android:color/transparent"
                    app:rippleColor="#20FFFFFF" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

                <!-- LOGIN -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_button"
                    android:text="@string/login_button_text"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:cornerRadius="29dp"
                    app:elevation="0dp"
                    app:rippleColor="#40FFFFFF" />

                <!-- GOOGLE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleLogin"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_button_secondary"
                    android:text="@string/login_google_button"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    app:backgroundTint="@null"
                    app:cornerRadius="29dp"
                    app:elevation="0dp"
                    app:rippleColor="#25FFFFFF" />

                <!-- VERIFICAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerificarCorreoLogin"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="@string/login_verify_email_text"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_neon"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:rippleColor="#20FFFFFF" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="14dp" />

                <!-- REGISTRO -->
                <TextView
                    android:id="@+id/textGoToRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center"
                    android:text="@string/login_goto_register"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>