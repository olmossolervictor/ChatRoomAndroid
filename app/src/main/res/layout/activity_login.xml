<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ELEMENTO DECORATIVO SUPERIOR (GLOW) -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-160dp"
        android:layout_marginEnd="-160dp"
        android:background="@drawable/bg_icon_chat"
        android:alpha="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollLogin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="48dp"
            android:gravity="center_horizontal">

            <!-- LOGO MODERNO EN TARJETA -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="80dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="30dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/border_subtle"
                app:cardElevation="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="26dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/primary" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvChatroom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Chatroom"
                android:textColor="@color/text_high"
                android:textSize="36sp"
                android:letterSpacing="-0.04" />

            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/login_subtitle"
                android:textColor="@color/text_medium"
                android:textSize="15sp"
                android:letterSpacing="0.02" />

            <!-- CONTENEDOR DE FORMULARIO (Tarjeta sutil) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:orientation="vertical">

                <!-- EMAIL -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/login_email_hint"
                    app:startIconDrawable="@android:drawable/ic_dialog_email">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_high"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- PASSWORD -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:hint="@string/login_password_hint"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@android:drawable/ic_lock_idle_lock">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="18dp"
                        android:inputType="textPassword"
                        android:textColor="@color/text_high"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/textResendVerification"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="@string/login_resend_prompt"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/poppins_bold"
                    android:visibility="gone" />

                <!-- BOTÓN PRINCIPAL -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/bg_button"
                    android:text="@string/login_button_text"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.04"
                    app:backgroundTint="@null"
                    app:cornerRadius="24dp"
                    app:elevation="8dp" />

                <!-- BOTÓN GOOGLE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleLogin"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/login_google_button"
                    android:textSize="15sp"
                    android:textColor="@color/text_high"
                    app:strokeColor="@color/border_active"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="24dp" />

                <!-- FOOTER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="48dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerificarCorreoLogin"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_verify_email_text"
                        android:textColor="@color/primary"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textGoToRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:text="@string/login_goto_register"
                        android:textColor="@color/text_high"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>