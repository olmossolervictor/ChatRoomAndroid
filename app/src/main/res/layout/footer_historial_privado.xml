<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/textTituloHistorialPrivado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de chats privados"
        android:textColor="#BDBDBD"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/textHistorialPrivadoVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aun no hay chats privados recientes"
        android:textColor="#8A8A8A"
        android:textSize="13sp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <LinearLayout
        android:id="@+id/layoutHistorialPrivadoItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
