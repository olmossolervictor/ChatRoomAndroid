<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="32dp"
    android:paddingBottom="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <View
            android:layout_width="12dp"
            android:layout_height="2dp"
            android:background="@color/primary"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/textTituloHistorialPrivado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHATS RECIENTES"
            android:textColor="@color/text_medium"
            android:fontFamily="@font/poppins_bold"
            android:textSize="12sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border_subtle"
        app:cardBackgroundColor="@color/bg_secondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/textHistorialPrivadoVacio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay conversaciones privadas activas"
                android:textColor="@color/text_low"
                android:fontFamily="@font/poppins_medium"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingVertical="32dp" />

            <LinearLayout
                android:id="@+id/layoutHistorialPrivadoItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>