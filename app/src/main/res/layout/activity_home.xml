<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingHorizontal="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageButton
                        android:id="@+id/btnMenuDrawer"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:padding="12dp"
                        app:tint="@color/text_high" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="@font/poppins_bold"
                        android:text="CHATHUB"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        android:letterSpacing="0.2" />

                </RelativeLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Hero Section con bienvenida -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/textWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Mis Salas"
                    android:textColor="@color/text_high"
                    android:textSize="34sp"
                    android:letterSpacing="-0.03"
                    android:lineSpacingExtra="-4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tus accesos activos por proximidad"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:alpha="0.9"/>
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- CONTENEDOR DE SALAS -->
                <LinearLayout
                    android:id="@+id/layoutConSalas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <ListView
                        android:id="@+id/listSalas"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="12dp"
                        android:paddingHorizontal="20dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        tools:listitem="@layout/item_sala" />

                    <!-- Botón de Acción Principal (Scan) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanQRHomeAbajo"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_margin="24dp"
                        android:background="@drawable/bg_button"
                        android:fontFamily="@font/poppins_bold"
                        android:text="ESCANEAR NUEVA SALA"
                        android:textColor="@color/white"
                        android:letterSpacing="0.02"
                        app:backgroundTint="@null"
                        app:cornerRadius="20dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        android:elevation="8dp"
                        android:stateListAnimator="@null" />
                </LinearLayout>

                <!-- ESTADO VACÍO PROFESIONAL -->
                <LinearLayout
                    android:id="@+id/layoutSinSalas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="40dp"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardCornerRadius="70dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/accent_soft"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_add"
                            app:tint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Todo despejado"
                        android:textColor="@color/text_high"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Escanea un código QR para unirte a una sala de chat segura."
                        android:textColor="@color/text_medium"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanQRHomeCentro"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginTop="40dp"
                        android:paddingHorizontal="40dp"
                        android:background="@drawable/bg_button"
                        android:text="EMPEZAR AHORA"
                        android:textColor="@color/white"
                        android:fontFamily="@font/poppins_bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="28dp"
                        android:elevation="4dp" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- SIDEBAR (DRAWER) REFINADO -->
    <LinearLayout
        android:layout_width="310dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface_card"
        android:orientation="vertical"
        android:elevation="16dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Header de Perfil con Estilo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="64dp"
            android:paddingBottom="32dp"
            android:background="@color/accent_soft">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="84dp"
                android:layout_height="84dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="4dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/white"
                app:cardBackgroundColor="@color/surface_card">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgDrawerFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@android:drawable/ic_menu_camera"
                    android:padding="2dp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textDrawerNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Usuario Premium"
                android:textColor="@color/text_high"
                android:textSize="22sp"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MIEMBRO VERIFICADO"
                android:textColor="@color/secondary_dark"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0.12"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="20dp"
            android:paddingHorizontal="16dp"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/drawerEditarPerfil"
                    style="@style/DrawerItemStylePremium"
                    android:text="Mi Cuenta"
                    android:drawableStart="@android:drawable/ic_menu_edit" />

                <RelativeLayout
                    android:id="@+id/drawerNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_drawer_item_selector"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="16dp"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Notificaciones"
                        android:textColor="@color/text_high"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium"
                        android:drawableStart="@android:drawable/ic_popup_reminder"
                        android:drawablePadding="18dp"
                        app:drawableTint="@color/primary" />

                    <TextView
                        android:id="@+id/drawerNotifBadge"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_circle_icon"
                        android:backgroundTint="@color/error_main"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_bold"
                        android:visibility="gone" />
                </RelativeLayout>

                <View style="@style/DrawerDivider" />

                <TextView
                    android:id="@+id/drawerAjustes"
                    style="@style/DrawerItemStylePremium"
                    android:text="Configuración"
                    android:drawableStart="@android:drawable/ic_menu_preferences"
                    app:drawableTint="@color/text_medium" />

                <TextView
                    android:id="@+id/drawerGestionUsuarios"
                    style="@style/DrawerItemStylePremium"
                    android:text="Admin Panel"
                    android:drawableStart="@android:drawable/ic_menu_manage"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/drawerTerminos"
                    style="@style/DrawerItemStylePremium"
                    android:text="Legal"
                    android:drawableStart="@android:drawable/ic_menu_info_details"
                    app:drawableTint="@color/text_medium" />

                <TextView
                    android:id="@+id/drawerDenuncias"
                    style="@style/DrawerItemStylePremium"
                    android:text="@string/drawer_denuncias"
                    android:drawableStart="@android:drawable/ic_menu_report_image"
                    app:drawableTint="@color/text_medium" />

            </LinearLayout>
        </ScrollView>

        <!-- Sección de Logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/drawerCerrarSesion"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Cerrar Sesión"
                android:textColor="@color/error_main"
                android:fontFamily="@font/poppins_bold"
                android:textSize="14sp"
                android:gravity="start|center_vertical"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/error_main"
                app:cornerRadius="16dp"
                android:backgroundTint="@color/error_bg" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
