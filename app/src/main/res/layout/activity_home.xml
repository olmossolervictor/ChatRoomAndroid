<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/textWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MIS SALAS"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#888888"
        android:layout_marginBottom="8dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <ListView
            android:id="@+id/listSalas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/darker_gray"
            android:dividerHeight="1dp"/>

        <TextView
            android:id="@+id/textEmptySalas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No estás en ninguna sala"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:textSize="15sp"
            android:visibility="gone"/>

    </FrameLayout>

    <Button
        android:id="@+id/btnScanQRHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESCANEAR QR"
        android:padding="14dp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnGPSHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ACTIVAR GPS"
        android:padding="14dp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnEditProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MODIFICAR REGISTRO"
        android:padding="14dp"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CERRAR SESIÓN"
        android:backgroundTint="@android:color/holo_red_dark"/>

</LinearLayout>
