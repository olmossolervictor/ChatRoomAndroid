<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:paddingHorizontal="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMenuDrawer"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_centerVertical="true"
                        android:visibility="visible"
                        app:icon="@drawable/icono_drawer"
                        app:iconSize="24dp"
                        app:iconTint="@color/text_high" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:fontFamily="@font/poppins_bold"
                        android:letterSpacing="0"
                        android:text="CHATROOM"
                        android:textColor="@color/primary"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAbandonarGlobal"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:visibility="gone"
                        app:icon="@drawable/icon_logout"
                        app:iconSize="24dp"
                        app:iconTint="@color/error_main" />
                </RelativeLayout>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/textWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0"
                    android:lineSpacingExtra="-4dp"
                    android:text="Mis Salas"
                    android:textColor="@color/text_high"
                    android:textSize="30sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.9"
                    android:text="Tus accesos activos por proximidad"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp" />
            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/layoutConSalas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <ListView
                        android:id="@+id/listSalas"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="12dp"
                        android:overScrollMode="never"
                        android:paddingHorizontal="20dp"
                        tools:listitem="@layout/item_sala" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanQRHomeAbajo"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_margin="24dp"
                        android:background="@drawable/bg_button"
                        android:elevation="0dp"
                        android:fontFamily="@font/poppins_bold"
                        android:letterSpacing="0"
                        android:stateListAnimator="@null"
                        android:text="ESCANEAR NUEVA SALA"
                        android:textColor="@color/white"
                        app:backgroundTint="@null"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/icono_camera"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconSize="24dp"
                        app:iconTint="@color/white" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutSinSalas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="40dp"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        app:cardBackgroundColor="@color/accent_soft"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_add"
                            app:tint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Todo despejado"
                        android:textColor="@color/text_high"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="Escanea un código QR para unirte a una sala de chat segura."
                        android:textColor="@color/text_medium"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScanQRHomeCentro"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginTop="40dp"
                        android:background="@drawable/bg_button"
                        android:elevation="0dp"
                        android:fontFamily="@font/poppins_bold"
                        android:paddingHorizontal="40dp"
                        android:text="EMPEZAR AHORA"
                        android:textColor="@color/white"
                        app:backgroundTint="@null"
                        app:cornerRadius="28dp" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <LinearLayout
        android:layout_width="310dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface_card"
        android:clickable="true"
                android:elevation="0dp"
        android:focusable="true"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_main"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="64dp"
            android:paddingBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="84dp"
                android:layout_height="84dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_subtle"
                app:strokeWidth="1dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgDrawerFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:src="@android:drawable/ic_menu_camera" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textDrawerNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0"
                android:text="Usuario Premium"
                android:textColor="@color/text_high"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0"
                android:text="MIEMBRO VERIFICADO"
                android:textColor="@color/secondary_dark"
                android:textSize="11sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/drawerEditarPerfil"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="start|center_vertical"
                    android:text="Mi Cuenta"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/icono_edit"
                    app:iconTint="@color/text_high"
                    app:iconSize="28dp"/>

                <RelativeLayout
                    android:id="@+id/drawerNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="start|center_vertical"
                        android:text="Notificaciones"
                        android:textColor="@color/text_high"
                        android:textSize="15sp"
                        app:cornerRadius="16dp"
                        app:icon="@drawable/icon_notification"
                        app:iconTint="@color/text_high"
                        app:iconSize="28dp"
                        android:clickable="false"
                        android:focusable="false"
                        android:duplicateParentState="true" />

                    <TextView
                        android:id="@+id/drawerNotifBadge"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_circle_icon"
                        android:backgroundTint="@color/error_main"
                        android:fontFamily="@font/poppins_bold"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:elevation="2dp"
                        android:visibility="gone" />

                </RelativeLayout>

                <View style="@style/DrawerDivider" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/drawerAjustes"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="start|center_vertical"
                    android:text="Ajustes"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/icon_setting"
                    app:iconTint="@color/text_high"
                    app:iconSize="28dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/drawerGestionUsuarios"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="start|center_vertical"
                    android:text="Panel de Control"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/icon_administration"
                    app:iconTint="@color/text_high"
                    app:iconSize="28dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/drawerTerminos"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="start|center_vertical"
                    android:text="Terminos y Condiciones"
                    android:textColor="@color/text_high"
                    android:textSize="15sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/icon_information"
                    app:iconTint="@color/text_high"
                    app:iconSize="28dp"/>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/drawerCerrarSesion"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/error_bg"
                android:fontFamily="@font/poppins_bold"
                android:gravity="start|center_vertical"
                android:text="Cerrar Sesión"
                android:textColor="@color/error_main"
                android:textSize="14sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="@color/error_main" />
        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
