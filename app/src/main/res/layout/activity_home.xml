<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout: activity_home.xml
    Rediseño Premium Nightclub - 100% Funcional sin cambios de lógica.
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".activities.HomeActivity">

    <!-- CONTENIDO PRINCIPAL -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_main">

        <!-- DECORACIÓN: GLOW SUPERIOR (Identidad visual de la App) -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_marginTop="-150dp"
            android:layout_marginStart="-150dp"
            android:background="@drawable/bg_icon_chat"
            android:alpha="0.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- HEADER / TOOLBAR PERSONALIZADA -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnMenuDrawer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_secondary"
                android:contentDescription="Menú de navegación"
                android:padding="12dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:tint="@color/text_high" />

            <TextView
                android:id="@+id/textWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Mis Salas"
                android:textColor="@color/text_high"
                android:textSize="26sp"
                android:letterSpacing="-0.02"
                app:layout_constraintStart_toEndOf="@id/btnMenuDrawer"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- CONTENEDOR DE CONTENIDO (Estilo Tarjeta Elevada) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@drawable/bg_home_surface"
            android:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/header">

            <!-- VISTA: LISTADO DE SALAS ACTIVAS -->
            <LinearLayout
                android:id="@+id/layoutConSalas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ListView
                    android:id="@+id/listSalas"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="16dp"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="32dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never" />

                <!-- BOTÓN FLOTANTE / ACCIÓN PRINCIPAL -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScanQRHomeAbajo"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_margin="24dp"
                    android:backgroundTint="@color/primary"
                    android:text="ESCANEAR NUEVA SALA"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_bold"
                    android:letterSpacing="0.04"
                    app:cornerRadius="20dp"
                    app:elevation="8dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp" />
            </LinearLayout>

            <!-- VISTA: ESTADO VACÍO (Sin Salas registradas) -->
            <LinearLayout
                android:id="@+id/layoutSinSalas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="40dp"
                android:visibility="gone"
                tools:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="@color/surface_highlight"
                    app:cardCornerRadius="80dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="45dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/primary" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/textEmptySalas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center"
                    android:text="El mundo te espera.\nEscanea un código QR."
                    android:textColor="@color/text_high"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"
                    android:lineSpacingExtra="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScanQRHomeCentro"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:paddingHorizontal="40dp"
                    android:text="ESCANEAR AHORA"
                    android:fontFamily="@font/poppins_bold"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/primary" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MENÚ LATERAL (DRAWER PREMIUM) -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/bg_main"
        android:clickable="true"
        android:focusable="true">

        <!-- CABECERA DEL DRAWER (Perfil de Usuario) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_drawer_neon"
            android:padding="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgDrawerFoto"
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:src="@android:drawable/ic_menu_camera"
                app:civ_border_width="3dp"
                app:civ_border_color="@color/white"
                app:layout_constraintBottom_toTopOf="@id/textDrawerNombre"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/textDrawerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenido,"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                app:layout_constraintBottom_toTopOf="@id/textDrawerNombre"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/textDrawerNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- LISTADO DE OPCIONES DEL MENÚ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingTop="16dp"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/drawerEditarPerfil"
                    style="@style/Widget.App.DrawerItem"
                    android:text="Mi Cuenta"
                    android:drawableStart="@android:drawable/ic_menu_edit" />

                <!-- NOTIFICACIONES CON BADGE DINÁMICO -->
                <RelativeLayout
                    android:id="@+id/drawerNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_drawer_item">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notificaciones"
                        android:textColor="@color/text_high"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold"
                        android:drawableStart="@android:drawable/ic_popup_reminder"
                        android:drawablePadding="16dp"
                        android:layout_centerVertical="true" />

                    <TextView
                        android:id="@+id/drawerNotifBadge"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_empty_state_icon"
                        android:backgroundTint="@color/error_main"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:visibility="gone" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/drawerAjustes"
                    style="@style/Widget.App.DrawerItem"
                    android:text="Ajustes de App"
                    android:drawableStart="@android:drawable/ic_menu_preferences" />

                <TextView
                    android:id="@+id/drawerGestionUsuarios"
                    style="@style/Widget.App.DrawerItem"
                    android:text="Administración"
                    android:drawableStart="@android:drawable/ic_menu_manage"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/drawerTerminos"
                    style="@style/Widget.App.DrawerItem"
                    android:text="Centro Legal"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/drawerDenuncias"
                    style="@style/Widget.App.DrawerItem"
                    android:text="Reportar un problema"
                    android:textColor="@color/text_medium"
                    android:textSize="14sp" />

            </LinearLayout>
        </ScrollView>

        <!-- SECCIÓN DE CIERRE DE SESIÓN -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle" />

        <TextView
            android:id="@+id/drawerCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:textColor="@color/error_main"
            android:textSize="15sp"
            android:padding="24dp"
            android:fontFamily="@font/poppins_bold"
            android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
            android:drawablePadding="16dp"
            android:drawableTint="@color/error_main"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>