<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1565C0"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnMenuDrawer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menú"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/textWelcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INICIO"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingStart="8dp"/>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/layoutConSalas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"> <ListView
                android:id="@+id/listSalas"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="16dp"
                android:divider="@android:color/darker_gray"
                android:dividerHeight="1dp"/>

                <Button
                    android:id="@+id/btnScanQRHomeAbajo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:text="ESCANEAR NUEVO QR"
                    android:padding="14dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutSinSalas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#CCCCCC"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/textEmptySalas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No estás en ninguna sala."
                    android:textColor="#888888"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnScanQRHomeCentro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESCANEAR QR"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"/>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="#1565C0"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgDrawerFoto"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_camera"
                app:civ_border_width="2dp"
                app:civ_border_color="#FFFFFF"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola,"
                android:textColor="#CCE0FF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/textDrawerNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="..."
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <TextView
            android:id="@+id/drawerEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Editar perfil"
            android:textSize="15sp"
            android:padding="18dp"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <RelativeLayout
            android:id="@+id/drawerNotificaciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="  Notificaciones"
                android:textSize="15sp"
                android:drawableStart="@android:drawable/ic_popup_reminder"
                android:drawablePadding="12dp"/>

            <TextView
                android:id="@+id/drawerNotifBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="#FF5252"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:gravity="center"
                android:visibility="gone"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/drawerAjustes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Ajustes"
            android:textSize="15sp"
            android:padding="18dp"
            android:drawableStart="@android:drawable/ic_menu_preferences"
            android:drawablePadding="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/drawerGestionUsuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Gestión de usuarios"
            android:textSize="15sp"
            android:padding="18dp"
            android:drawableStart="@android:drawable/ic_menu_manage"
            android:drawablePadding="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/drawerTerminos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Términos y condiciones"
            android:textSize="13sp"
            android:textColor="#888888"
            android:padding="18dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/drawerDenuncias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Denuncias"
            android:textSize="13sp"
            android:textColor="#888888"
            android:padding="18dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"/>

        <TextView
            android:id="@+id/drawerCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  Cerrar sesión"
            android:textSize="15sp"
            android:textColor="#D32F2F"
            android:padding="18dp"
            android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
            android:drawablePadding="12dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp"/>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>