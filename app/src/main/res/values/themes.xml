<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 🎨 TEMA BASE (Material 3) -->
    <style name="Base.Theme.Chat" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores Principales -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/accent_soft</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fondos y Barras de Sistema -->
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <!-- Superficies y Textos -->
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_high</item>
        <item name="colorSurfaceVariant">@color/bg_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_medium</item>

        <item name="android:textColorPrimary">@color/text_high</item>
        <item name="android:textColorSecondary">@color/text_medium</item>
        <item name="android:fontFamily">@font/poppins_regular</item>

        <!-- Estilos de Componentes Globales -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
    </style>

    <style name="Theme.Chat" parent="Base.Theme.Chat">
        <item name="android:datePickerDialogTheme">@style/Theme.App.DatePicker</item>
    </style>

    <!-- 💎 TOOLBAR STYLE -->
    <style name="TextAppearance.App.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">@color/text_title</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- 💎 DRAWER (MENÚ LATERAL) PREMIUM -->
    <style name="DrawerItemStylePremium">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_high</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:drawablePadding">18dp</item>
        <item name="android:background">@drawable/bg_drawer_item_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:drawableTint">@color/primary</item>
    </style>

    <style name="DrawerDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/border_subtle</item>
        <item name="android:layout_marginVertical">12dp</item>
        <item name="android:layout_marginHorizontal">16dp</item>
    </style>

    <!-- ⌨️ INPUTS Y TARJETAS -->
    <style name="Widget.App.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxBackgroundColor">@color/surface_card</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="android:textColorHint">@color/text_low</item>
    </style>

    <style name="Widget.App.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- 🔢 ESTILO PARA VERIFICACIÓN (DÍGITOS) -->
    <style name="DigitFieldStyle" parent="">
        <item name="android:background">@drawable/bg_circle_icon</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_high</item>
    </style>

    <!-- 🗓️ CALENDARIO -->
    <style name="Theme.App.DatePicker" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:datePickerMode">calendar</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:headerBackground">@color/primary</item>
        <item name="android:calendarTextColor">@color/text_high</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="ThemeOverlay.App.MaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_high</item>
        <item name="colorOnSurfaceVariant">@color/text_medium</item>
        <item name="materialCalendarStyle">@style/Widget.App.MaterialCalendar</item>
        <item name="materialCalendarHeaderSelection">@style/Widget.App.MaterialCalendar.HeaderSelection</item>
        <item name="materialCalendarHeaderToggleButton">@style/Widget.App.MaterialCalendar.HeaderToggleButton</item>
    </style>

    <style name="Widget.App.MaterialCalendar" parent="Widget.Material3.MaterialCalendar">
        <item name="android:windowBackground">@color/surface_card</item>
    </style>

    <style name="Widget.App.MaterialCalendar.HeaderSelection" parent="Widget.Material3.MaterialCalendar.HeaderSelection">
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
    </style>

    <style name="Widget.App.MaterialCalendar.HeaderToggleButton" parent="Widget.Material3.MaterialCalendar.HeaderToggleButton">
        <item name="android:tint">@color/white</item>
    </style>

</resources>