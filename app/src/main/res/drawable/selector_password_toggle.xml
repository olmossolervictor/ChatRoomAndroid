<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Contraseña visible -->
    <item android:state_checked="true">
        <layer-list>
            <item android:width="24dp" android:height="24dp" android:gravity="center" android:drawable="@drawable/icon_show" />
        </layer-list>
    </item>
    <!-- Contraseña oculta -->
    <item>
        <layer-list>
            <item android:width="24dp" android:height="24dp" android:gravity="center" android:drawable="@drawable/icon_hide" />
        </layer-list>
    </item>
</selector>