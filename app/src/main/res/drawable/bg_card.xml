<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo con profundidad -->
    <gradient
        android:startColor="#1E1E1E"
        android:endColor="#141414"
        android:angle="270"/>

    <!-- Bordes redondeados -->
    <corners android:radius="28dp"/>

    <!-- Borde suave -->
    <stroke
        android:width="1dp"
        android:color="#2F2F2F"/>

    <!-- Padding interno (clave para que respire mejor) -->
    <padding
        android:left="6dp"
        android:right="6dp"
        android:top="6dp"
        android:bottom="6dp"/>

</shape>