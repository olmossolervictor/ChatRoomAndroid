<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo más elegante -->
    <gradient
        android:startColor="#202020"
        android:endColor="#121212"
        android:angle="270"/>

    <!-- Bordes -->
    <corners android:radius="30dp"/>

    <!-- Borde más sutil -->
    <stroke
        android:width="1dp"
        android:color="#333333"/>

    <!-- Padding interno -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="8dp"
        android:bottom="8dp"/>

</shape>