<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Chat" parent="Base.Theme.Chat">
        <!-- En modo oscuro, los iconos de la barra de estado deben ser blancos -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>

        <!-- Refinamiento de contraste para modo noche -->
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorSurfaceVariant">@color/bg_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_medium</item>

        <!-- Elevación y bordes de componentes -->
        <item name="materialCardViewStyle">@style/Widget.App.CardView.Night</item>
    </style>

    <!-- Estilo de tarjeta específico para modo noche -->
    <style name="Widget.App.CardView.Night" parent="Widget.App.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Ajuste de DatePicker para modo noche -->
    <style name="Theme.App.DatePicker.Night" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:datePickerMode">calendar</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:headerBackground">@color/bg_secondary</item>
        <item name="android:calendarTextColor">@color/text_high</item>
        <item name="android:windowBackground">@color/bg_main</item>
    </style>
</resources>